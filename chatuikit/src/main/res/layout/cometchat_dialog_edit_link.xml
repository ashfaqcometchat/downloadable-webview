<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cometchat_edit_link_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/cometchat_margin_6"
    app:cardBackgroundColor="?attr/cometchatBackgroundColor1"
    app:cardCornerRadius="@dimen/cometchat_radius_4"
    app:cardElevation="@dimen/cometchat_spacing_2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/cometchat_padding_6">

        <!-- Title -->
        <TextView
            android:id="@+id/cometchat_dialog_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/cometchat_margin_3"
            android:text="@string/cometchat_link"
            android:textAppearance="?attr/cometchatTextAppearanceHeading2Bold"
            android:textColor="?attr/cometchatTextColorPrimary" />

        <!-- Link URL (Clickable) -->
        <TextView
            android:id="@+id/cometchat_link_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/cometchat_margin_5"
            android:textAppearance="?attr/cometchatTextAppearanceBodyRegular"
            android:textColor="?attr/cometchatPrimaryColor"
            tools:text="https://example.com" />

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cometchat_edit_button"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/cometchat_margin_2"
                android:layout_weight="1"
                android:text="@string/cometchat_edit"
                android:textAllCaps="false"
                android:textAppearance="?attr/cometchatTextAppearanceButtonMedium"
                android:textColor="?attr/cometchatTextColorPrimary"
                app:backgroundTint="?attr/cometchatBackgroundColor1"
                app:cornerRadius="@dimen/cometchat_radius_2"
                app:strokeColor="?attr/cometchatStrokeColorDefault"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cometchat_remove_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/cometchat_margin_2"
                android:layout_weight="1"
                android:text="@string/cometchat_remove"
                android:textAllCaps="false"
                android:textAppearance="?attr/cometchatTextAppearanceButtonMedium"
                android:textColor="?attr/cometchatTextColorWhite"
                app:backgroundTint="?attr/cometchatErrorColor"
                app:cornerRadius="@dimen/cometchat_radius_2" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
