<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/chat_history_item_parent"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="3dp">

        <TextView
            android:id="@+id/tv_message_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginStart="@dimen/cometchat_margin_4"
            android:layout_marginTop="@dimen/cometchat_margin_3"
            android:layout_marginBottom="@dimen/cometchat_margin_3"
            android:layout_marginEnd="@dimen/cometchat_margin_4"/>

</LinearLayout>