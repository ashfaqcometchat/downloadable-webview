        <attr name="cometchatGroupsEmptyStateTextAppearance" format="reference" />
        <attr name="cometchatGroupsEmptyStateTextColor" format="color" />
        <attr name="cometchatGroupsEmptyStateSubTitleTextAppearance" format="reference" />

