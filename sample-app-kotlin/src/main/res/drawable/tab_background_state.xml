<?xml version="1.0" encoding="utf-8"?>
<!--
    Tab Background State Selector
    
    Defines the background for selected and unselected tab states.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:drawable="@drawable/tab_layout_background_active" android:state_selected="true" />
    <item android:drawable="@android:color/transparent" android:state_selected="false" />

</selector>
