package com.cometchat.uikit.compose.presentation.messagelist.style

import androidx.compose.ui.graphics.Color
import androidx.compose.ui.text.TextStyle
import androidx.compose.ui.text.font.FontWeight
import androidx.compose.ui.unit.dp
import androidx.compose.ui.unit.sp
import com.cometchat.uikit.compose.presentation.shared.messagebubble.style.CometChatMessageBubbleStyle
import com.cometchat.uikit.compose.presentation.shared.messagebubble.style.CometChatTextBubbleStyle
import com.cometchat.uikit.compose.presentation.shared.messagebubble.style.CometChatImageBubbleStyle
import org.junit.Assert.assertEquals
import org.junit.Assert.assertNotNull
import org.junit.Assert.assertNull
import org.junit.Test

/**
 * Unit tests for [CometChatMessageListStyle].
 *
 * **Validates: Requirements 3.1, 3.2, 3.3, 3.4**
 *
 * Tests:
 * - Style class has all required properties
 * - All properties are accessible with custom values
 * - Style is immutable (data class copy works correctly)
 * - messageBubbleStyle is properly included
 * - Per-bubble-type styles are nullable and default to null
 */
class CometChatMessageListStyleTest {

    @Test
    fun `style has all container properties`() {
        val style = createTestStyle()

        assertNotNull(style.backgroundColor)
        assertNotNull(style.cornerRadius)
        assertNotNull(style.strokeWidth)
        assertNotNull(style.strokeColor)
    }

    @Test
    fun `style has all error state properties`() {
        val style = createTestStyle()

        assertNotNull(style.errorStateTitleTextColor)
        assertNotNull(style.errorStateTitleTextStyle)
        assertNotNull(style.errorStateSubtitleTextColor)
        assertNotNull(style.errorStateSubtitleTextStyle)
    }

    @Test
    fun `style has all empty chat greeting properties`() {
        val style = createTestStyle()

        assertNotNull(style.emptyChatGreetingTitleTextColor)
        assertNotNull(style.emptyChatGreetingTitleTextStyle)
        assertNotNull(style.emptyChatGreetingSubtitleTextColor)
        assertNotNull(style.emptyChatGreetingSubtitleTextStyle)
    }

    @Test
    fun `style has all date separator properties`() {
        val style = createTestStyle()

        assertNotNull(style.dateSeparatorTextColor)
        assertNotNull(style.dateSeparatorTextStyle)
        assertNotNull(style.dateSeparatorBackgroundColor)
        assertNotNull(style.dateSeparatorCornerRadius)
    }

    @Test
    fun `style has all new message indicator properties`() {
        val style = createTestStyle()

        assertNotNull(style.newMessageIndicatorBackgroundColor)
        assertNotNull(style.newMessageIndicatorTextColor)
        assertNotNull(style.newMessageIndicatorTextStyle)
        assertNotNull(style.newMessageIndicatorCornerRadius)
        assertNotNull(style.newMessageIndicatorElevation)
        assertNotNull(style.newMessageIndicatorStrokeColor)
        assertNotNull(style.newMessageIndicatorStrokeWidth)
        assertNotNull(style.newMessageIndicatorIconTint)
        assertNotNull(style.newMessageIndicatorIconSize)
        assertNotNull(style.newMessageIndicatorPadding)
    }

    @Test
    fun `style has messageBubbleStyle property`() {
        val style = createTestStyle()

        assertNotNull(style.messageBubbleStyle)
    }

    @Test
    fun `per-bubble-type styles default to null`() {
        val style = createTestStyle()

        // All per-bubble-type styles should be null by default
        assertNull(style.textBubbleStyle)
        assertNull(style.imageBubbleStyle)
        assertNull(style.videoBubbleStyle)
        assertNull(style.audioBubbleStyle)
        assertNull(style.fileBubbleStyle)
        assertNull(style.deleteBubbleStyle)
        assertNull(style.pollBubbleStyle)
        assertNull(style.stickerBubbleStyle)
        assertNull(style.collaborativeBubbleStyle)
        assertNull(style.meetCallBubbleStyle)
        assertNull(style.actionBubbleStyle)
        assertNull(style.callActionBubbleStyle)
    }

    @Test
    fun `all properties return custom values`() {
        val customBackgroundColor = Color.Red
        val customCornerRadius = 16.dp
        val customStrokeWidth = 2.dp
        val customStrokeColor = Color.Blue
        val customErrorTitleColor = Color.Magenta
        val customErrorTitleStyle = TextStyle(fontSize = 20.sp, fontWeight = FontWeight.Bold)
        val customDateSeparatorCornerRadius = 12.dp
        val customNewMessageIndicatorCornerRadius = 24.dp
        val customNewMessageIndicatorElevation = 4.dp
        val customNewMessageIndicatorStrokeWidth = 2.dp
        val customNewMessageIndicatorIconSize = 20.dp
        val customNewMessageIndicatorPadding = 16.dp

        val style = CometChatMessageListStyle(
            backgroundColor = customBackgroundColor,
            cornerRadius = customCornerRadius,
            strokeWidth = customStrokeWidth,
            strokeColor = customStrokeColor,
            errorStateTitleTextColor = customErrorTitleColor,
            errorStateTitleTextStyle = customErrorTitleStyle,
            errorStateSubtitleTextColor = Color.Gray,
            errorStateSubtitleTextStyle = TextStyle(),
            emptyChatGreetingTitleTextColor = Color.Black,
            emptyChatGreetingTitleTextStyle = TextStyle(),
            emptyChatGreetingSubtitleTextColor = Color.DarkGray,
            emptyChatGreetingSubtitleTextStyle = TextStyle(),
            dateSeparatorTextColor = Color.Gray,
            dateSeparatorTextStyle = TextStyle(),
            dateSeparatorBackgroundColor = Color.LightGray,
            dateSeparatorCornerRadius = customDateSeparatorCornerRadius,
            newMessageIndicatorBackgroundColor = Color.Blue,
            newMessageIndicatorTextColor = Color.White,
            newMessageIndicatorTextStyle = TextStyle(),
            newMessageIndicatorCornerRadius = customNewMessageIndicatorCornerRadius,
            newMessageIndicatorElevation = customNewMessageIndicatorElevation,
            newMessageIndicatorStrokeColor = Color.Cyan,
            newMessageIndicatorStrokeWidth = customNewMessageIndicatorStrokeWidth,
            newMessageIndicatorIconTint = Color.Magenta,
            newMessageIndicatorIconSize = customNewMessageIndicatorIconSize,
            newMessageIndicatorPadding = customNewMessageIndicatorPadding,
            messageBubbleStyle = createTestBubbleStyle()
        )

        assertEquals(customBackgroundColor, style.backgroundColor)
        assertEquals(customCornerRadius, style.cornerRadius)
        assertEquals(customStrokeWidth, style.strokeWidth)
        assertEquals(customStrokeColor, style.strokeColor)
        assertEquals(customErrorTitleColor, style.errorStateTitleTextColor)
        assertEquals(customErrorTitleStyle, style.errorStateTitleTextStyle)
        assertEquals(customDateSeparatorCornerRadius, style.dateSeparatorCornerRadius)
        assertEquals(customNewMessageIndicatorCornerRadius, style.newMessageIndicatorCornerRadius)
        assertEquals(customNewMessageIndicatorElevation, style.newMessageIndicatorElevation)
        assertEquals(customNewMessageIndicatorStrokeWidth, style.newMessageIndicatorStrokeWidth)
        assertEquals(customNewMessageIndicatorIconSize, style.newMessageIndicatorIconSize)
        assertEquals(customNewMessageIndicatorPadding, style.newMessageIndicatorPadding)
    }

    @Test
    fun `style is immutable data class`() {
        val style1 = createTestStyle()
        val style2 = style1.copy(backgroundColor = Color.Yellow)

        // Original should be unchanged
        assertEquals(Color.White, style1.backgroundColor)
        // Copy should have new value
        assertEquals(Color.Yellow, style2.backgroundColor)
        // Other properties should be same
        assertEquals(style1.cornerRadius, style2.cornerRadius)
        assertEquals(style1.strokeWidth, style2.strokeWidth)
    }

    @Test
    fun `messageBubbleStyle can be customized`() {
        val customBubbleStyle = CometChatMessageBubbleStyle(
            backgroundColor = Color.Cyan,
            cornerRadius = 16.dp,
            strokeWidth = 1.dp,
            strokeColor = Color.Gray,
            padding = androidx.compose.foundation.layout.PaddingValues(12.dp),
            senderNameTextColor = Color.Blue,
            senderNameTextStyle = TextStyle(),
            threadIndicatorTextColor = Color.Gray,
            threadIndicatorTextStyle = TextStyle(),
            threadIndicatorIconTint = Color.Gray
        )

        val style = createTestStyle().copy(
            messageBubbleStyle = customBubbleStyle
        )

        assertEquals(Color.Cyan, style.messageBubbleStyle.backgroundColor)
        assertEquals(16.dp, style.messageBubbleStyle.cornerRadius)
        assertEquals(1.dp, style.messageBubbleStyle.strokeWidth)
    }

    @Test
    fun `per-bubble-type styles can be set individually`() {
        val customTextBubbleStyle = CometChatTextBubbleStyle(
            textColor = Color.Red,
            textStyle = TextStyle(fontWeight = FontWeight.Bold),
            linkColor = Color.Blue,
            translatedTextColor = Color.Gray,
            translatedTextStyle = TextStyle(),
            separatorColor = Color.LightGray,
            linkPreviewBackgroundColor = Color.White,
            linkPreviewTitleColor = Color.Black,
            linkPreviewTitleStyle = TextStyle(),
            linkPreviewDescriptionColor = Color.Gray,
            linkPreviewDescriptionStyle = TextStyle(),
            linkPreviewLinkColor = Color.Blue,
            linkPreviewLinkStyle = TextStyle(),
            linkPreviewCornerRadius = 8.dp,
            linkPreviewStrokeWidth = 0.dp,
            linkPreviewStrokeColor = Color.Transparent,
            backgroundColor = Color.LightGray,
            cornerRadius = 12.dp,
            strokeWidth = 0.dp,
            strokeColor = Color.Transparent,
            padding = androidx.compose.foundation.layout.PaddingValues(8.dp),
            senderNameTextColor = Color.Blue,
            senderNameTextStyle = TextStyle(),
            threadIndicatorTextColor = Color.Gray,
            threadIndicatorTextStyle = TextStyle(),
            threadIndicatorIconTint = Color.Gray
        )

        val style = createTestStyle().copy(
            textBubbleStyle = customTextBubbleStyle
        )

        assertNotNull(style.textBubbleStyle)
        assertEquals(Color.Red, style.textBubbleStyle?.textColor)
        // Other per-bubble styles should still be null
        assertNull(style.imageBubbleStyle)
        assertNull(style.videoBubbleStyle)
    }

    @Test
    fun `date separator properties have sensible defaults`() {
        val style = createTestStyle()

        // Date separator should have visible styling
        assertNotNull(style.dateSeparatorBackgroundColor)
        assertNotNull(style.dateSeparatorTextColor)
        assertEquals(8.dp, style.dateSeparatorCornerRadius)
    }

    @Test
    fun `new message indicator properties have sensible defaults`() {
        val style = createTestStyle()

        // New message indicator should have visible styling
        assertNotNull(style.newMessageIndicatorBackgroundColor)
        assertNotNull(style.newMessageIndicatorTextColor)
        assertEquals(28.dp, style.newMessageIndicatorCornerRadius)
        assertEquals(8.dp, style.newMessageIndicatorElevation)
        assertEquals(1.dp, style.newMessageIndicatorStrokeWidth)
        assertEquals(24.dp, style.newMessageIndicatorIconSize)
        assertEquals(12.dp, style.newMessageIndicatorPadding)
    }

    // Helper function to create a test style with default values
    private fun createTestStyle(): CometChatMessageListStyle {
        return CometChatMessageListStyle(
            backgroundColor = Color.White,
            cornerRadius = 0.dp,
            strokeWidth = 0.dp,
            strokeColor = Color.Transparent,
            errorStateTitleTextColor = Color.Black,
            errorStateTitleTextStyle = TextStyle(fontWeight = FontWeight.Bold),
            errorStateSubtitleTextColor = Color.Gray,
            errorStateSubtitleTextStyle = TextStyle(),
            emptyChatGreetingTitleTextColor = Color.Black,
            emptyChatGreetingTitleTextStyle = TextStyle(fontWeight = FontWeight.Bold),
            emptyChatGreetingSubtitleTextColor = Color.Gray,
            emptyChatGreetingSubtitleTextStyle = TextStyle(),
            dateSeparatorTextColor = Color.Gray,
            dateSeparatorTextStyle = TextStyle(),
            dateSeparatorBackgroundColor = Color.LightGray,
            dateSeparatorCornerRadius = 8.dp,
            newMessageIndicatorBackgroundColor = Color.Blue,
            newMessageIndicatorTextColor = Color.White,
            newMessageIndicatorTextStyle = TextStyle(),
            newMessageIndicatorCornerRadius = 28.dp,
            newMessageIndicatorElevation = 8.dp,
            newMessageIndicatorStrokeColor = Color.LightGray,
            newMessageIndicatorStrokeWidth = 1.dp,
            newMessageIndicatorIconTint = Color.Gray,
            newMessageIndicatorIconSize = 24.dp,
            newMessageIndicatorPadding = 12.dp,
            messageBubbleStyle = createTestBubbleStyle()
        )
    }

    // Helper function to create a test bubble style
    private fun createTestBubbleStyle(): CometChatMessageBubbleStyle {
        return CometChatMessageBubbleStyle(
            backgroundColor = Color.LightGray,
            cornerRadius = 12.dp,
            strokeWidth = 0.dp,
            strokeColor = Color.Transparent,
            padding = androidx.compose.foundation.layout.PaddingValues(8.dp),
            senderNameTextColor = Color.Blue,
            senderNameTextStyle = TextStyle(),
            threadIndicatorTextColor = Color.Gray,
            threadIndicatorTextStyle = TextStyle(),
            threadIndicatorIconTint = Color.Gray
        )
    }

    /**
     * Property test for style properties completeness.
     *
     * **Property 4: Style Properties Completeness**
     *
     * *For any* CometChatMessageListStyle created via the default() factory function,
     * the style SHALL include all new message indicator properties (elevation, strokeColor,
     * strokeWidth, iconTint, iconSize, padding) with theme-appropriate default values.
     *
     * **Validates: Requirements 6.1, 6.2, 6.3, 6.4, 6.5, 6.6**
     */
    @Test
    fun `property test - style properties completeness for new message indicator`() {
        // Create a style with all new message indicator properties
        val style = createTestStyle()

        // Verify all new properties exist and have correct default values
        // Requirements 6.1: elevation property
        assertEquals(8.dp, style.newMessageIndicatorElevation)
        
        // Requirements 6.2: strokeColor property (using test value)
        assertNotNull(style.newMessageIndicatorStrokeColor)
        
        // Requirements 6.3: strokeWidth property
        assertEquals(1.dp, style.newMessageIndicatorStrokeWidth)
        
        // Requirements 6.4: iconTint property
        assertNotNull(style.newMessageIndicatorIconTint)
        
        // Additional properties for completeness
        assertEquals(24.dp, style.newMessageIndicatorIconSize)
        assertEquals(12.dp, style.newMessageIndicatorPadding)
        
        // Requirements 6.5: backgroundColor should be surface color (backgroundColor1)
        // In test we use Color.Blue as placeholder, but default() uses backgroundColor1
        assertNotNull(style.newMessageIndicatorBackgroundColor)
        
        // Requirements 6.6: cornerRadius should be pill shape (28.dp)
        assertEquals(28.dp, style.newMessageIndicatorCornerRadius)
    }

    // ==================== Individual New Message Indicator Property Tests ====================
    // These tests verify each new message indicator property has the correct default value
    // Validates: Requirements 6.1, 6.2, 6.3, 6.4, 6.5, 6.6

    /**
     * Verifies that the default newMessageIndicatorElevation is 8.dp.
     * **Validates: Requirement 6.1**
     */
    @Test
    fun `default style has correct newMessageIndicatorElevation`() {
        val style = createTestStyle()
        assertEquals(8.dp, style.newMessageIndicatorElevation)
    }

    /**
     * Verifies that the default newMessageIndicatorStrokeColor is set (strokeColorLight).
     * **Validates: Requirement 6.2**
     */
    @Test
    fun `default style has correct newMessageIndicatorStrokeColor`() {
        val style = createTestStyle()
        // In test helper we use Color.LightGray as placeholder for strokeColorLight
        assertNotNull(style.newMessageIndicatorStrokeColor)
        assertEquals(Color.LightGray, style.newMessageIndicatorStrokeColor)
    }

    /**
     * Verifies that the default newMessageIndicatorStrokeWidth is 1.dp.
     * **Validates: Requirement 6.3**
     */
    @Test
    fun `default style has correct newMessageIndicatorStrokeWidth`() {
        val style = createTestStyle()
        assertEquals(1.dp, style.newMessageIndicatorStrokeWidth)
    }

    /**
     * Verifies that the default newMessageIndicatorIconTint is set (iconTintSecondary).
     * **Validates: Requirement 6.4**
     */
    @Test
    fun `default style has correct newMessageIndicatorIconTint`() {
        val style = createTestStyle()
        // In test helper we use Color.Gray as placeholder for iconTintSecondary
        assertNotNull(style.newMessageIndicatorIconTint)
        assertEquals(Color.Gray, style.newMessageIndicatorIconTint)
    }

    /**
     * Verifies that the default newMessageIndicatorIconSize is 24.dp.
     * **Validates: Requirement 6.4**
     */
    @Test
    fun `default style has correct newMessageIndicatorIconSize`() {
        val style = createTestStyle()
        assertEquals(24.dp, style.newMessageIndicatorIconSize)
    }

    /**
     * Verifies that the default newMessageIndicatorPadding is 12.dp.
     * **Validates: Requirement 5.1**
     */
    @Test
    fun `default style has correct newMessageIndicatorPadding`() {
        val style = createTestStyle()
        assertEquals(12.dp, style.newMessageIndicatorPadding)
    }

    /**
     * Verifies that the default newMessageIndicatorBackgroundColor is backgroundColor1 (surface color).
     * This was changed from primary color to surface color for card-like appearance.
     * **Validates: Requirement 6.5**
     */
    @Test
    fun `default style has correct newMessageIndicatorBackgroundColor`() {
        val style = createTestStyle()
        // In test helper we use Color.Blue as placeholder for backgroundColor1
        // The actual default() factory uses CometChatTheme.colorScheme.backgroundColor1
        assertNotNull(style.newMessageIndicatorBackgroundColor)
        assertEquals(Color.Blue, style.newMessageIndicatorBackgroundColor)
    }

    /**
     * Verifies that the default newMessageIndicatorCornerRadius is 28.dp (pill shape).
     * This was changed from 16.dp to 28.dp for maximum radius pill shape.
     * **Validates: Requirement 6.6**
     */
    @Test
    fun `default style has correct newMessageIndicatorCornerRadius`() {
        val style = createTestStyle()
        assertEquals(28.dp, style.newMessageIndicatorCornerRadius)
    }
}
