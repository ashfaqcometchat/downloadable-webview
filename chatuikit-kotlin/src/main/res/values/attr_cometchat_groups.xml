        <attr name="cometchatGroupsRetryButtonBackgroundColor" format="color" />
        <attr name="cometchatGroupsRetryButtonStrokeColor" format="color" />
        <attr name="cometchatGroupsRetryButtonStrokeWidth" format="dimension" />
        <attr name="cometchatGroupsRetryButtonCornerRadius" format="dimension" />

