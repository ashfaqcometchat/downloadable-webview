        <attr name="cometchatGroupsErrorStateTextAppearance" format="reference" />
        <attr name="cometchatGroupsErrorStateTextColor" format="color" />
        <attr name="cometchatGroupsErrorStateSubtitleTextAppearance" format="reference" />
        <attr name="cometchatGroupsErrorStateSubtitleColor" format="color" />

