        <attr name="cometchatGroupsSearchInputStartIcon" format="reference" />
        <attr name="cometchatGroupsSearchInputStartIconTint" format="color" />
        <attr name="cometchatGroupsSearchInputEndIcon" format="reference" />
        <attr name="cometchatGroupsSearchInputEndIconTint" format="color" />
        <attr name="cometchatGroupsSearchInputCornerRadius" format="dimension" />
        <attr name="cometchatGroupsSearchInputStrokeWidth" format="dimension" />
        <attr name="cometchatGroupsSearchInputStrokeColor" format="color" />
        <!-- Legacy search icon attributes for backward compatibility -->
        <attr name="cometchatGroupsSearchInputIcon" format="reference" />
        <attr name="cometchatGroupsSearchInputIconTint" format="color" />

        <!-- Item styling -->
        <attr name="cometchatGroupsItemBackgroundColor" format="color" />
        <attr name="cometchatGroupsItemSelectedBackgroundColor" format="color" />
        <attr name="cometchatGroupsItemTitleTextColor" format="color" />
        <attr name="cometchatGroupsItemTitleTextAppearance" format="reference" />
        <attr name="cometchatGroupsSubtitleColor" format="color" />
        <attr name="cometchatGroupsSubtitleTextAppearance" format="reference" />

        <!-- Checkbox styling -->
        <attr name="cometchatGroupsCheckBoxStrokeWidth" format="dimension" />
