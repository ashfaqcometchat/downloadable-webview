<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="end"
    android:orientation="vertical">

    <!-- Date view for conversation timestamp -->
    <com.cometchat.uikit.kotlin.presentation.shared.baseelements.date.CometChatDate
        android:id="@+id/date_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAlignment="viewEnd"
        tools:text="12:30 PM" />

    <!-- Badge view for unread message count -->
    <com.cometchat.uikit.kotlin.presentation.shared.baseelements.badgecount.CometChatBadgeCount
        android:id="@+id/badge_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/cometchat_margin_1"
        android:visibility="gone"
        tools:visibility="visible" />

</LinearLayout>
