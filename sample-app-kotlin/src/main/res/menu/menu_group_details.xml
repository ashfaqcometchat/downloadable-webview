<?xml version="1.0" encoding="utf-8"?>
<menu xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Add Members - visible for admins/owners -->
    <item
        android:id="@+id/action_add_members"
        android:icon="@drawable/ic_add_member"
        android:title="@string/add_members"
        android:visible="false"
        app:showAsAction="ifRoom" />

    <!-- Leave Group - visible for non-owners -->
    <item
        android:id="@+id/action_leave_group"
        android:icon="@drawable/ic_exit"
        android:title="@string/leave_group"
        app:showAsAction="ifRoom" />

    <!-- Delete Group - visible only for owners -->
    <item
        android:id="@+id/action_delete_group"
        android:icon="@drawable/ic_delete"
        android:title="@string/delete_group"
        android:visible="false"
        app:showAsAction="never" />

</menu>
