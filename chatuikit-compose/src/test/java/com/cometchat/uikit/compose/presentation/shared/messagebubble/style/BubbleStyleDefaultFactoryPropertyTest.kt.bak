// ============================================================================
// Helper functions to create default style instances without Compose context
// These simulate what the default() factory functions would return
// ============================================================================

/**
 * Expected default values for wrapper properties (simulating CometChatTheme).
 */
private object ExpectedDefaults {
    val backgroundColor2 = Color(0xFFFAFAFA) // neutralColor100
    val cornerRadius = 12.dp
    val strokeWidth = 0.dp
    val strokeColor = Color.Transparent
    val padding = PaddingValues(0.dp)
    val senderNameTextColor = Color(0xFF727272) // neutralColor600 - textColorSecondary
    val senderNameTextStyle = TextStyle(fontSize = 12.sp) // caption1Medium
    val threadIndicatorTextColor = Color(0xFF727272) // neutralColor600 - textColorSecondary
    val threadIndicatorTextStyle = TextStyle(fontSize = 12.sp) // caption1Regular
    val threadIndicatorIconTint = Color(0xFFA1A1A1) // neutralColor500 - iconTintSecondary
    
    // Content-specific defaults
    val textColorPrimary = Color(0xFF141414) // neutralColor900
    val textColorSecondary = Color(0xFF727272) // neutralColor600
    val primary = Color(0xFF6852D6) // primaryColorLight
    val strokeColorLight = Color(0xFFE8E8E8) // neutralColor300
    val backgroundColor3 = Color(0xFFF5F5F5) // neutralColor200
    val iconTintSecondary = Color(0xFFA1A1A1) // neutralColor500
}

/**
 * Creates a default CometChatTextBubbleStyle instance simulating default() factory.
 */
private fun createDefaultTextBubbleStyle(): CometChatTextBubbleStyle = CometChatTextBubbleStyle(
    // Content-specific properties
    textColor = ExpectedDefaults.textColorPrimary,
    textStyle = TextStyle(fontSize = 14.sp),
    linkColor = ExpectedDefaults.primary,
    translatedTextColor = ExpectedDefaults.textColorSecondary,
    translatedTextStyle = TextStyle(fontSize = 12.sp),
    separatorColor = ExpectedDefaults.strokeColorLight,
    linkPreviewBackgroundColor = ExpectedDefaults.backgroundColor3,
    linkPreviewTitleColor = ExpectedDefaults.textColorPrimary,
    linkPreviewTitleStyle = TextStyle(fontSize = 14.sp),
    linkPreviewDescriptionColor = ExpectedDefaults.textColorSecondary,
    linkPreviewDescriptionStyle = TextStyle(fontSize = 12.sp),
    linkPreviewLinkColor = ExpectedDefaults.primary,
    linkPreviewLinkStyle = TextStyle(fontSize = 12.sp),
    linkPreviewCornerRadius = 8.dp,
    linkPreviewStrokeWidth = 0.dp,
    linkPreviewStrokeColor = Color.Transparent,
    // Wrapper properties
    backgroundColor = ExpectedDefaults.backgroundColor2,
    cornerRadius = ExpectedDefaults.cornerRadius,
    strokeWidth = ExpectedDefaults.strokeWidth,
    strokeColor = ExpectedDefaults.strokeColor,
    padding = ExpectedDefaults.padding,
    senderNameTextColor = ExpectedDefaults.senderNameTextColor,
    senderNameTextStyle = ExpectedDefaults.senderNameTextStyle,
    threadIndicatorTextColor = ExpectedDefaults.threadIndicatorTextColor,
    threadIndicatorTextStyle = ExpectedDefaults.threadIndicatorTextStyle,
    threadIndicatorIconTint = ExpectedDefaults.threadIndicatorIconTint
)


/**
 * Creates a default CometChatImageBubbleStyle instance simulating default() factory.
 */
private fun createDefaultImageBubbleStyle(): CometChatImageBubbleStyle = CometChatImageBubbleStyle(
    // Content-specific properties
    imageCornerRadius = 8.dp,
    imageStrokeWidth = 0.dp,
    imageStrokeColor = Color.Transparent,
    captionTextColor = ExpectedDefaults.textColorPrimary,
    captionTextStyle = TextStyle(fontSize = 14.sp),
    progressIndicatorColor = ExpectedDefaults.iconTintSecondary,
    gridSpacing = 2.dp,
    maxGridWidth = 240.dp,
    moreOverlayBackgroundColor = Color.Black.copy(alpha = 0.6f),
    moreOverlayTextColor = Color.White,
    moreOverlayTextStyle = TextStyle(fontSize = 18.sp),
    // Wrapper properties
    backgroundColor = ExpectedDefaults.backgroundColor2,
    cornerRadius = ExpectedDefaults.cornerRadius,
    strokeWidth = ExpectedDefaults.strokeWidth,
    strokeColor = ExpectedDefaults.strokeColor,
    padding = ExpectedDefaults.padding,
    senderNameTextColor = ExpectedDefaults.senderNameTextColor,
    senderNameTextStyle = ExpectedDefaults.senderNameTextStyle,
    threadIndicatorTextColor = ExpectedDefaults.threadIndicatorTextColor,
    threadIndicatorTextStyle = ExpectedDefaults.threadIndicatorTextStyle,
    threadIndicatorIconTint = ExpectedDefaults.threadIndicatorIconTint
)

