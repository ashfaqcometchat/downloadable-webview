<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="CometChatFlagMessage">
        <attr name="cometChatFlagMessageStyle" format="reference"/>
        <!-- Dialog Styling -->
        <attr name="cometchatFlagMessageBackgroundColor" format="color"/>
        <attr name="cometchatFlagMessageBorderRadius" format="dimension"/>
        <attr name="cometchatFlagMessageTitleColor" format="color"/>
        <attr name="cometchatFlagMessageSubtitleColor" format="color"/>
        <attr name="cometchatFlagMessageTitleAppearance" format="reference"/>
        <attr name="cometchatFlagMessageSubtitleTextAppearance" format="reference"/>
