<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="@dimen/cometchat_12dp"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/cometchatNeutralColor300"
    app:cardElevation="0dp"
    android:layout_marginTop="@dimen/cometchat_10dp"
    android:layout_marginBottom="@dimen/cometchat_10dp"
    app:cardBackgroundColor="?attr/cometchatBackgroundColor1">

    <HorizontalScrollView
        android:id="@+id/horizontal_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:scrollbarStyle="outsideInset">

        <TableLayout
            android:id="@+id/table_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:collapseColumns="*"
            />

    </HorizontalScrollView>

</com.google.android.material.card.MaterialCardView>