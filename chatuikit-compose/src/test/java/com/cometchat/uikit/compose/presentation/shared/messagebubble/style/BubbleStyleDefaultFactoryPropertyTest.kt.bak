import io.kotest.property.arbitrary.constant
import io.kotest.property.checkAll

/**
 * Property-based tests for verifying that per-bubble default() factory methods
 * produce instances with correct wrapper properties.
 *
 * **Feature: bubble-style-propagation**
 * **Property 2: Per-bubble default() factory methods produce instances with correct wrapper properties**
 *
 * **Validates: Requirements 2.4**
 *
 * For any per-bubble-type style class, calling `default()` should produce an instance where
 * the inherited wrapper properties (backgroundColor, cornerRadius, strokeWidth, strokeColor,
 * padding, senderNameTextColor, senderNameTextStyle, threadIndicatorTextColor,
 * threadIndicatorTextStyle, threadIndicatorIconTint) match the expected CometChatTheme
 * default values for that bubble type.
 */
class BubbleStyleDefaultFactoryPropertyTest : StringSpec({

    // ============================================================================
    // Expected default values for wrapper properties (simulating CometChatTheme)
    // ============================================================================

    /**
     * Expected default wrapper property values that match CometChatTheme defaults.
     * These simulate what CometChatTheme.colorScheme and typography would return.
     */
    val expectedBackgroundColor2 = Color(0xFFFAFAFA) // neutralColor100 - backgroundColor2
    val expectedCornerRadius = 12.dp
    val expectedStrokeWidth = 0.dp
    val expectedStrokeColor = Color.Transparent
    val expectedPadding = PaddingValues(0.dp)
    val expectedSenderNameTextColor = Color(0xFF727272) // neutralColor600 - textColorSecondary
    val expectedSenderNameTextStyle = TextStyle(fontSize = 12.sp) // caption1Medium
    val expectedThreadIndicatorTextColor = Color(0xFF727272) // neutralColor600 - textColorSecondary
    val expectedThreadIndicatorTextStyle = TextStyle(fontSize = 12.sp) // caption1Regular
    val expectedThreadIndicatorIconTint = Color(0xFFA1A1A1) // neutralColor500 - iconTintSecondary

    // Special case: Sticker bubble uses transparent background
    val expectedStickerBackgroundColor = Color.Transparent

    // ============================================================================
    // Property Test: CometChatTextBubbleStyle default() produces correct wrapper properties
    // ============================================================================

    /**
     * Property test: CometChatTextBubbleStyle.default() produces correct wrapper properties.
     *
     * **Validates: Requirements 2.4**
     */
    "CometChatTextBubbleStyle default() should produce correct wrapper properties" {
        // Use constant Arb to run 100 iterations verifying the same invariant
        val iterationArb = Arb.constant(Unit)

        checkAll(100, iterationArb) {
            val style = createDefaultTextBubbleStyle()

            // Verify all wrapper properties match expected defaults
            style.backgroundColor shouldBe expectedBackgroundColor2
            style.cornerRadius shouldBe expectedCornerRadius
            style.strokeWidth shouldBe expectedStrokeWidth
            style.strokeColor shouldBe expectedStrokeColor
            style.padding shouldBe expectedPadding
            style.senderNameTextColor shouldBe expectedSenderNameTextColor
            style.senderNameTextStyle.fontSize shouldBe expectedSenderNameTextStyle.fontSize
            style.threadIndicatorTextColor shouldBe expectedThreadIndicatorTextColor
            style.threadIndicatorTextStyle.fontSize shouldBe expectedThreadIndicatorTextStyle.fontSize
            style.threadIndicatorIconTint shouldBe expectedThreadIndicatorIconTint
        }
    }

    // ============================================================================
    // Property Test: CometChatImageBubbleStyle default() produces correct wrapper properties
    // ============================================================================

    /**
     * Property test: CometChatImageBubbleStyle.default() produces correct wrapper properties.
     *
     * **Validates: Requirements 2.4**
     */
    "CometChatImageBubbleStyle default() should produce correct wrapper properties" {
        val iterationArb = Arb.constant(Unit)

        checkAll(100, iterationArb) {
            val style = createDefaultImageBubbleStyle()

            // Verify all wrapper properties match expected defaults
            style.backgroundColor shouldBe expectedBackgroundColor2
            style.cornerRadius shouldBe expectedCornerRadius
            style.strokeWidth shouldBe expectedStrokeWidth
            style.strokeColor shouldBe expectedStrokeColor
            style.padding shouldBe expectedPadding
            style.senderNameTextColor shouldBe expectedSenderNameTextColor
            style.senderNameTextStyle.fontSize shouldBe expectedSenderNameTextStyle.fontSize
            style.threadIndicatorTextColor shouldBe expectedThreadIndicatorTextColor
            style.threadIndicatorTextStyle.fontSize shouldBe expectedThreadIndicatorTextStyle.fontSize
            style.threadIndicatorIconTint shouldBe expectedThreadIndicatorIconTint
        }
    }

    // ============================================================================
    // Property Test: CometChatVideoBubbleStyle default() produces correct wrapper properties
    // ============================================================================

    /**
     * Property test: CometChatVideoBubbleStyle.default() produces correct wrapper properties.
     *
     * **Validates: Requirements 2.4**
     */
    "CometChatVideoBubbleStyle default() should produce correct wrapper properties" {
        val iterationArb = Arb.constant(Unit)

        checkAll(100, iterationArb) {
            val style = createDefaultVideoBubbleStyle()

            // Verify all wrapper properties match expected defaults
            style.backgroundColor shouldBe expectedBackgroundColor2
            style.cornerRadius shouldBe expectedCornerRadius
            style.strokeWidth shouldBe expectedStrokeWidth
            style.strokeColor shouldBe expectedStrokeColor
            style.padding shouldBe expectedPadding
            style.senderNameTextColor shouldBe expectedSenderNameTextColor
            style.senderNameTextStyle.fontSize shouldBe expectedSenderNameTextStyle.fontSize
            style.threadIndicatorTextColor shouldBe expectedThreadIndicatorTextColor
            style.threadIndicatorTextStyle.fontSize shouldBe expectedThreadIndicatorTextStyle.fontSize
            style.threadIndicatorIconTint shouldBe expectedThreadIndicatorIconTint
        }
    }

    // ============================================================================
    // Property Test: CometChatAudioBubbleStyle default() produces correct wrapper properties
    // ============================================================================

    /**
     * Property test: CometChatAudioBubbleStyle.default() produces correct wrapper properties.
     *
     * **Validates: Requirements 2.4**
     */
    "CometChatAudioBubbleStyle default() should produce correct wrapper properties" {
        val iterationArb = Arb.constant(Unit)

        checkAll(100, iterationArb) {
            val style = createDefaultAudioBubbleStyle()

            // Verify all wrapper properties match expected defaults
            style.backgroundColor shouldBe expectedBackgroundColor2
            style.cornerRadius shouldBe expectedCornerRadius
            style.strokeWidth shouldBe expectedStrokeWidth
            style.strokeColor shouldBe expectedStrokeColor
            style.padding shouldBe expectedPadding
            style.senderNameTextColor shouldBe expectedSenderNameTextColor
            style.senderNameTextStyle.fontSize shouldBe expectedSenderNameTextStyle.fontSize
            style.threadIndicatorTextColor shouldBe expectedThreadIndicatorTextColor
            style.threadIndicatorTextStyle.fontSize shouldBe expectedThreadIndicatorTextStyle.fontSize
            style.threadIndicatorIconTint shouldBe expectedThreadIndicatorIconTint
        }
    }

    // ============================================================================
    // Property Test: CometChatFileBubbleStyle default() produces correct wrapper properties
    // ============================================================================

    /**
     * Property test: CometChatFileBubbleStyle.default() produces correct wrapper properties.
     *
     * **Validates: Requirements 2.4**
     */
    "CometChatFileBubbleStyle default() should produce correct wrapper properties" {
        val iterationArb = Arb.constant(Unit)

        checkAll(100, iterationArb) {
            val style = createDefaultFileBubbleStyle()

            // Verify all wrapper properties match expected defaults
            style.backgroundColor shouldBe expectedBackgroundColor2
            style.cornerRadius shouldBe expectedCornerRadius
            style.strokeWidth shouldBe expectedStrokeWidth
            style.strokeColor shouldBe expectedStrokeColor
            style.padding shouldBe expectedPadding
            style.senderNameTextColor shouldBe expectedSenderNameTextColor
            style.senderNameTextStyle.fontSize shouldBe expectedSenderNameTextStyle.fontSize
            style.threadIndicatorTextColor shouldBe expectedThreadIndicatorTextColor
            style.threadIndicatorTextStyle.fontSize shouldBe expectedThreadIndicatorTextStyle.fontSize
            style.threadIndicatorIconTint shouldBe expectedThreadIndicatorIconTint
        }
    }

    // ============================================================================
    // Property Test: CometChatDeleteBubbleStyle default() produces correct wrapper properties
    // ============================================================================

    /**
     * Property test: CometChatDeleteBubbleStyle.default() produces correct wrapper properties.
     *
     * **Validates: Requirements 2.4**
     */
    "CometChatDeleteBubbleStyle default() should produce correct wrapper properties" {
        val iterationArb = Arb.constant(Unit)

        checkAll(100, iterationArb) {
            val style = createDefaultDeleteBubbleStyle()

            // Verify all wrapper properties match expected defaults
            style.backgroundColor shouldBe expectedBackgroundColor2
            style.cornerRadius shouldBe expectedCornerRadius
            style.strokeWidth shouldBe expectedStrokeWidth
            style.strokeColor shouldBe expectedStrokeColor
            style.padding shouldBe expectedPadding
            style.senderNameTextColor shouldBe expectedSenderNameTextColor
            style.senderNameTextStyle.fontSize shouldBe expectedSenderNameTextStyle.fontSize
            style.threadIndicatorTextColor shouldBe expectedThreadIndicatorTextColor
            style.threadIndicatorTextStyle.fontSize shouldBe expectedThreadIndicatorTextStyle.fontSize
            style.threadIndicatorIconTint shouldBe expectedThreadIndicatorIconTint
        }
    }

    // ============================================================================
    // Property Test: CometChatStickerBubbleStyle default() produces correct wrapper properties
    // ============================================================================

    /**
     * Property test: CometChatStickerBubbleStyle.default() produces correct wrapper properties.
     * Note: Sticker bubbles use transparent background by default.
     *
     * **Validates: Requirements 2.4**
     */
    "CometChatStickerBubbleStyle default() should produce correct wrapper properties with transparent background" {
        val iterationArb = Arb.constant(Unit)

        checkAll(100, iterationArb) {
            val style = createDefaultStickerBubbleStyle()

            // Verify all wrapper properties match expected defaults
            // Note: Sticker uses transparent background
            style.backgroundColor shouldBe expectedStickerBackgroundColor
            style.cornerRadius shouldBe expectedCornerRadius
            style.strokeWidth shouldBe expectedStrokeWidth
            style.strokeColor shouldBe expectedStrokeColor
            style.padding shouldBe expectedPadding
            style.senderNameTextColor shouldBe expectedSenderNameTextColor
            style.senderNameTextStyle.fontSize shouldBe expectedSenderNameTextStyle.fontSize
            style.threadIndicatorTextColor shouldBe expectedThreadIndicatorTextColor
            style.threadIndicatorTextStyle.fontSize shouldBe expectedThreadIndicatorTextStyle.fontSize
            style.threadIndicatorIconTint shouldBe expectedThreadIndicatorIconTint
