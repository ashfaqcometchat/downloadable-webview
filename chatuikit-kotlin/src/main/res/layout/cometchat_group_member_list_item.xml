<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cometchat_parent_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="@dimen/cometchat_padding_4"
        android:paddingTop="@dimen/cometchat_padding_3"
        android:paddingEnd="@dimen/cometchat_padding_4"
        android:paddingBottom="@dimen/cometchat_padding_3">

        <!-- Selection Checkbox -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cometchat_checkbox_view"
            android:layout_width="@dimen/cometchat_20dp"
            android:layout_height="@dimen/cometchat_20dp"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="@dimen/cometchat_margin_3"
            android:visibility="gone">

            <ImageView
                android:id="@+id/cometchat_iv_checkbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:padding="@dimen/cometchat_padding_1"
                tools:ignore="ContentDescription" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Avatar with Status Indicator -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cometchat_leading_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical">

            <com.cometchat.uikit.kotlin.presentation.shared.baseelements.avatar.CometChatAvatar
                android:id="@+id/cometchat_member_avatar"
                android:layout_width="@dimen/cometchat_40dp"
                android:layout_height="@dimen/cometchat_40dp"
                tools:ignore="MissingConstraints" />

            <com.cometchat.uikit.kotlin.presentation.shared.statusindicator.CometChatStatusIndicator
                android:id="@+id/cometchat_member_status_indicator"
                android:layout_width="@dimen/cometchat_15dp"
                android:layout_height="@dimen/cometchat_15dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Content Area (Name and Subtitle) -->
        <LinearLayout
            android:id="@+id/cometchat_content_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="@dimen/cometchat_margin_3"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Title View Container -->
            <LinearLayout
                android:id="@+id/cometchat_title_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Member Name -->
                <TextView
                    android:id="@+id/cometchat_member_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    tools:text="John Doe" />

            </LinearLayout>

            <!-- Subtitle View Container -->
            <LinearLayout
                android:id="@+id/cometchat_subtitle_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />

        </LinearLayout>

        <!-- Scope Chip Badge (matches original Java MaterialCardView) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cometchat_scope_card"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="16dp"
            app:cardBackgroundColor="?attr/cometchatPrimaryColor"
            app:cardCornerRadius="@dimen/cometchat_radius_max"
            app:cardElevation="@dimen/cometchat_0dp"
            app:strokeColor="?attr/cometchatPrimaryColor"
            app:strokeWidth="@dimen/cometchat_1dp">

            <TextView
                android:id="@+id/cometchat_scope_text"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:paddingStart="@dimen/cometchat_padding_3"
                android:paddingTop="@dimen/cometchat_padding_1"
                android:paddingEnd="@dimen/cometchat_padding_3"
                android:paddingBottom="@dimen/cometchat_padding_1"
                android:text="@string/cometchat_owner"
                android:textAppearance="?attr/cometchatTextAppearanceCaption1Regular"
                android:textColor="?attr/cometchatColorWhite" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Tail View Container (custom trailing content only, no default overflow icon) -->
        <LinearLayout
            android:id="@+id/cometchat_tail_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="@dimen/cometchat_margin_4"
            android:orientation="vertical"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Separator -->
    <View
        android:id="@+id/cometchat_separator"
        android:layout_width="match_parent"
        android:layout_height="0.6dp"
        android:layout_marginStart="@dimen/cometchat_padding_4"
        android:layout_marginEnd="@dimen/cometchat_padding_4"
        android:background="@color/cometchat_color_stroke_light"
        android:visibility="visible" />

</LinearLayout>
