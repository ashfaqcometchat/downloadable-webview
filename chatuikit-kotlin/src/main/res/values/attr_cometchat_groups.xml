        <attr name="cometchatGroupsCheckBoxSelectIcon" format="reference" />
        <attr name="cometchatGroupsCheckBoxSelectIconTint" format="color" />

        <!-- Empty state styling -->
        <attr name="cometchatGroupsEmptyStateTitleTextColor" format="color" />
        <attr name="cometchatGroupsEmptyStateSubtitleTextColor" format="color" />
        <attr name="cometchatGroupsEmptyStateTextTitleAppearance" format="reference" />
        <attr name="cometchatGroupsEmptyStateTextSubtitleAppearance" format="reference" />
