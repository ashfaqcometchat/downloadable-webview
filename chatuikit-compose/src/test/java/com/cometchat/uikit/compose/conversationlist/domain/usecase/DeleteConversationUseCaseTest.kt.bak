package com.cometchat.uikit.compose.conversationlist.domain.usecase

import com.cometchat.chat.constants.CometChatConstants
import com.cometchat.chat.core.ConversationsRequest
import com.cometchat.chat.exceptions.CometChatException
import com.cometchat.chat.models.Conversation
import com.cometchat.chat.models.Group
import com.cometchat.chat.models.User
import com.cometchat.uikit.compose.domain.repository.ConversationListRepository
import com.cometchat.uikit.compose.domain.usecase.DeleteConversationUseCase
import io.kotest.core.spec.style.StringSpec
import io.kotest.matchers.shouldBe
import io.kotest.matchers.types.shouldBeInstanceOf
import kotlinx.coroutines.test.runTest
import org.mockito.Mockito.mock
import org.mockito.Mockito.`when`

/**
 * Unit tests for DeleteConversationUseCase.
 * 
 * Feature: conversations-compose
 * Tests verify use case extracts conversation ID correctly and calls repository.
 */
class DeleteConversationUseCaseTest : StringSpec({

    "invoke should delete user conversation successfully" {
        runTest {
            // Arrange
            var deletedWith: String? = null
            var deletedType: String? = null
            
            val mockRepository = object : ConversationListRepository {
                override suspend fun getConversations(request: ConversationsRequest): Result<List<Conversation>> {
                    return Result.success(emptyList())
                }
                override suspend fun deleteConversation(conversationWith: String, conversationType: String): Result<Unit> {
                    deletedWith = conversationWith
                    deletedType = conversationType
                    return Result.success(Unit)
                }
                override suspend fun markAsDelivered(conversation: Conversation): Result<Unit> {
                    return Result.success(Unit)
                }
                override fun hasMoreConversations(): Boolean = true
            }
            
            val useCase = DeleteConversationUseCase(mockRepository)
            
            // Create mock user and conversation
            val mockUser = mock(User::class.java)
            `when`(mockUser.uid).thenReturn("user123")
            
            val mockConversation = mock(Conversation::class.java)
            `when`(mockConversation.conversationId).thenReturn("conv1")
            `when`(mockConversation.conversationType).thenReturn(CometChatConstants.CONVERSATION_TYPE_USER)
            `when`(mockConversation.conversationWith).thenReturn(mockUser)

            // Act
            val result = useCase(mockConversation)

            // Assert
            result.isSuccess shouldBe true
            deletedWith shouldBe "user123"
            deletedType shouldBe CometChatConstants.CONVERSATION_TYPE_USER
        }
    }

    "invoke should delete group conversation successfully" {
        runTest {
            // Arrange
            var deletedWith: String? = null
            var deletedType: String? = null
            
            val mockRepository = object : ConversationListRepository {
                override suspend fun getConversations(request: ConversationsRequest): Result<List<Conversation>> {
                    return Result.success(emptyList())
                }
                override suspend fun deleteConversation(conversationWith: String, conversationType: String): Result<Unit> {
                    deletedWith = conversationWith
                    deletedType = conversationType
                    return Result.success(Unit)
                }
                override suspend fun markAsDelivered(conversation: Conversation): Result<Unit> {
                    return Result.success(Unit)
                }
                override fun hasMoreConversations(): Boolean = true
            }
            
            val useCase = DeleteConversationUseCase(mockRepository)
            
            // Create mock group and conversation
            val mockGroup = mock(Group::class.java)
            `when`(mockGroup.guid).thenReturn("group456")
            
            val mockConversation = mock(Conversation::class.java)
            `when`(mockConversation.conversationId).thenReturn("conv2")
            `when`(mockConversation.conversationType).thenReturn(CometChatConstants.CONVERSATION_TYPE_GROUP)
            `when`(mockConversation.conversationWith).thenReturn(mockGroup)

            // Act
            val result = useCase(mockConversation)

            // Assert
            result.isSuccess shouldBe true
            deletedWith shouldBe "group456"
            deletedType shouldBe CometChatConstants.CONVERSATION_TYPE_GROUP
        }
    }

    "invoke should return failure for invalid conversation type" {
        runTest {
            // Arrange
            val mockRepository = object : ConversationListRepository {
                override suspend fun getConversations(request: ConversationsRequest): Result<List<Conversation>> {
                    return Result.success(emptyList())
                }
                override suspend fun deleteConversation(conversationWith: String, conversationType: String): Result<Unit> {
                    return Result.success(Unit)
                }
                override suspend fun markAsDelivered(conversation: Conversation): Result<Unit> {
                    return Result.success(Unit)
                }
                override fun hasMoreConversations(): Boolean = true
            }
            
            val useCase = DeleteConversationUseCase(mockRepository)
            
            val mockConversation = mock(Conversation::class.java)
            `when`(mockConversation.conversationId).thenReturn("conv3")
            `when`(mockConversation.conversationType).thenReturn("invalid_type")

            // Act
            val result = useCase(mockConversation)

            // Assert
            result.isFailure shouldBe true
            result.exceptionOrNull().shouldBeInstanceOf<IllegalArgumentException>()
        }
    }

    "invoke should return failure when repository delete fails" {
        runTest {
            // Arrange
            val exception = CometChatException("DELETE_ERROR", "Delete failed", "Cannot delete conversation")
            val mockRepository = object : ConversationListRepository {
                override suspend fun getConversations(request: ConversationsRequest): Result<List<Conversation>> {
                    return Result.success(emptyList())
                }
                override suspend fun deleteConversation(conversationWith: String, conversationType: String): Result<Unit> {
                    return Result.failure(exception)
                }
                override suspend fun markAsDelivered(conversation: Conversation): Result<Unit> {
                    return Result.success(Unit)
                }
                override fun hasMoreConversations(): Boolean = true
            }
            
            val useCase = DeleteConversationUseCase(mockRepository)
            
            val mockUser = mock(User::class.java)
            `when`(mockUser.uid).thenReturn("user123")
            
            val mockConversation = mock(Conversation::class.java)
            `when`(mockConversation.conversationId).thenReturn("conv1")
            `when`(mockConversation.conversationType).thenReturn(CometChatConstants.CONVERSATION_TYPE_USER)
            `when`(mockConversation.conversationWith).thenReturn(mockUser)

            // Act
            val result = useCase(mockConversation)

            // Assert
            result.isFailure shouldBe true
            result.exceptionOrNull().shouldBeInstanceOf<CometChatException>()
        }
    }

    "invoke should return failure for user conversation with null uid" {
        runTest {
            // Arrange
            val mockRepository = object : ConversationListRepository {
                override suspend fun getConversations(request: ConversationsRequest): Result<List<Conversation>> {
                    return Result.success(emptyList())
                }
                override suspend fun deleteConversation(conversationWith: String, conversationType: String): Result<Unit> {
                    return Result.success(Unit)
                }
                override suspend fun markAsDelivered(conversation: Conversation): Result<Unit> {
                    return Result.success(Unit)
                }
                override fun hasMoreConversations(): Boolean = true
            }
            
            val useCase = DeleteConversationUseCase(mockRepository)
            
            val mockUser = mock(User::class.java)
            `when`(mockUser.uid).thenReturn(null)
            
            val mockConversation = mock(Conversation::class.java)
            `when`(mockConversation.conversationId).thenReturn("conv1")
            `when`(mockConversation.conversationType).thenReturn(CometChatConstants.CONVERSATION_TYPE_USER)
            `when`(mockConversation.conversationWith).thenReturn(mockUser)

            // Act
            val result = useCase(mockConversation)

            // Assert
            result.isFailure shouldBe true
            result.exceptionOrNull().shouldBeInstanceOf<IllegalArgumentException>()
        }
    }
})
