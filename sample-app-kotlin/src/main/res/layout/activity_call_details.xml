<?xml version="1.0" encoding="utf-8"?>
<!--
    Call Details Activity Layout
    
    Displays call log details including:
    - Toolbar with back button and title
    - Message header showing the call recipient
    - Call info section with type, date, and duration
    
    Validates: Requirements 9.2
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/parent_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/cometchatBackgroundColor1"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    tools:context=".ui.calls.CallDetailsActivity">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/cometchat_64dp"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/cometchat_padding_4"
            android:paddingTop="@dimen/cometchat_padding_2"
            android:paddingEnd="@dimen/cometchat_padding_4"
            android:paddingBottom="@dimen/cometchat_padding_2">

            <ImageView
                android:id="@+id/toolbar_back_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:padding="@dimen/cometchat_padding_2"
                android:src="@drawable/cometchat_ic_back"
                app:tint="?attr/cometchatIconTintPrimary"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/toolbar_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/cometchat_margin_2"
                android:text="@string/call_details"
                android:textAppearance="?attr/cometchatTextAppearanceHeading1Bold"
                android:textColor="?attr/cometchatTextColorPrimary" />

        </LinearLayout>

    </LinearLayout>

    <View
        android:id="@+id/toolbar_divider"
        android:layout_width="match_parent"
        android:layout_height="@dimen/cometchat_1dp"
        android:background="?attr/cometchatStrokeColorLight" />

    <!-- Message Header showing call recipient -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="start"
        android:orientation="horizontal"
        android:paddingTop="@dimen/cometchat_padding_3"
        android:paddingBottom="@dimen/cometchat_padding_3">

        <com.cometchat.uikit.kotlin.presentation.messageheader.ui.CometChatMessageHeader
            android:id="@+id/message_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </LinearLayout>

    <View
        android:id="@+id/message_header_divider"
        android:layout_width="match_parent"
        android:layout_height="@dimen/cometchat_1dp"
        android:background="?attr/cometchatStrokeColorLight" />

    <!-- Call Info Section -->
    <LinearLayout
        android:id="@+id/info_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:background="?attr/cometchatBackgroundColor2"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/cometchat_padding_4"
        android:paddingTop="@dimen/cometchat_padding_3"
        android:paddingEnd="@dimen/cometchat_padding_4"
        android:paddingBottom="@dimen/cometchat_padding_3">

        <ImageView
            android:id="@+id/iv_info_icon"
            android:layout_width="@dimen/cometchat_24dp"
            android:layout_height="@dimen/cometchat_24dp"
            tools:ignore="ContentDescription" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/cometchat_margin_3"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_info_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/cometchatTextAppearanceHeading4Medium"
                android:textColor="?attr/cometchatTextColorPrimary" />

            <com.cometchat.uikit.kotlin.presentation.shared.baseelements.date.CometChatDate
                android:id="@+id/tv_info_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cometchat_margin_1" />

        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="@dimen/cometchat_1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tv_info_call_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/cometchat_margin_3"
            android:textAppearance="?attr/cometchatTextAppearanceHeading4Medium"
            android:textColor="?attr/cometchatTextColorSecondary" />

    </LinearLayout>

    <View
        android:id="@+id/info_layout_divider"
        android:layout_width="match_parent"
        android:layout_height="@dimen/cometchat_1dp"
        android:background="?attr/cometchatStrokeColorLight" />

    <!-- TabLayout for History/Participants/Recordings tabs (matching master-app-java) -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/cometchatBackgroundColor1"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabIndicatorColor="?attr/cometchatPrimaryColor"
        app:tabSelectedTextColor="?attr/cometchatPrimaryColor"
        app:tabTextColor="?attr/cometchatTextColorSecondary"
        app:tabTextAppearance="?attr/cometchatTextAppearanceBodyMedium" />

    <!-- ViewPager2 for tab content (matching master-app-java) -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>
