<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/parent_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="@dimen/cometchat_margin_3"
        android:layout_marginHorizontal="@dimen/cometchat_margin_4"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="@dimen/cometchat_24dp"
            android:layout_height="@dimen/cometchat_24dp"
            android:layout_marginEnd="@dimen/cometchat_margin_1"
            tools:ignore="ContentDescription" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/search_box_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/cometchat_margin_2"
            app:cardElevation="0dp">

            <LinearLayout
                android:id="@+id/search_box"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/cometchat_padding_4"
                android:paddingTop="@dimen/cometchat_padding_3"
                android:paddingEnd="@dimen/cometchat_padding_4"
                android:paddingBottom="@dimen/cometchat_padding_3">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/search_input"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="@string/cometchat_search"
                    android:imeOptions="actionSearch"
                    android:lines="1"
                    android:maxLines="1"
                    android:singleLine="true" />

                <ImageView
                    android:id="@+id/iv_clear"
                    android:layout_width="@dimen/cometchat_24dp"
                    android:layout_height="@dimen/cometchat_24dp"
                    android:layout_marginStart="@dimen/cometchat_margin_1"
                    tools:ignore="ContentDescription" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <com.google.android.flexbox.FlexboxLayout
        android:id="@+id/chipGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:layout_marginVertical="@dimen/cometchat_margin_1"
        android:layout_marginHorizontal="@dimen/cometchat_margin_4"
        app:flexWrap="wrap"
        app:justifyContent="flex_start"/>

    <LinearLayout
        android:id="@+id/loading_state_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:layout_margin="@dimen/cometchat_margin_3"
        android:orientation="vertical"
        android:visibility="gone">

        <com.cometchat.chatuikit.shimmer.CometChatShimmerFrameLayout
            android:id="@+id/shimmer_effect_frame"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/shimmer_recyclerview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
        </com.cometchat.chatuikit.shimmer.CometChatShimmerFrameLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/initial_state_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_initial_state"
            android:layout_width="@dimen/cometchat_120dp"
            android:layout_height="@dimen/cometchat_120dp"
            tools:ignore="ContentDescription" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cometchat_margin_5">

            <TextView
                android:id="@+id/tv_initial_state_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/cometchat_margin_2"
                android:layout_marginEnd="@dimen/cometchat_margin_2"
                android:gravity="center"
                android:text="@string/cometchat_start_your_search"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_percent="0.8" />

            <TextView
                android:id="@+id/tv_initial_state_subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/cometchat_margin_2"
                android:layout_marginTop="@dimen/cometchat_margin_2"
                android:layout_marginEnd="@dimen/cometchat_margin_2"
                android:gravity="center"
                android:text="@string/cometchat_search_for_conversations_or_messages"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_initial_state_title"
                app:layout_constraintWidth_percent="0.8" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/empty_state_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_empty_state"
            android:layout_width="@dimen/cometchat_120dp"
            android:layout_height="@dimen/cometchat_120dp"
            tools:ignore="ContentDescription" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cometchat_margin_5">

            <TextView
                android:id="@+id/tv_empty_state_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/cometchat_margin_2"
                android:layout_marginEnd="@dimen/cometchat_margin_2"
                android:gravity="center"
                android:text="@string/cometchat_no_results"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_percent="0.8" />

            <TextView
                android:id="@+id/tv_empty_state_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/cometchat_margin_2"
                android:layout_marginTop="@dimen/cometchat_margin_2"
                android:layout_marginEnd="@dimen/cometchat_margin_2"
                android:gravity="center"
                android:text="@string/cometchat_no_matches_found"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_empty_state_title"
                app:layout_constraintWidth_percent="0.8" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/error_state_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cometchat_margin_5">

            <TextView
                android:id="@+id/tv_error_state_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/cometchat_margin_2"
                android:layout_marginEnd="@dimen/cometchat_margin_2"
                android:gravity="center"
                android:text="@string/cometchat_user_list_error_state_title"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_percent="0.8" />

            <TextView
                android:id="@+id/tv_error_state_subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/cometchat_margin_2"
                android:layout_marginTop="@dimen/cometchat_margin_2"
                android:layout_marginEnd="@dimen/cometchat_margin_2"
                android:gravity="center"
                android:text="@string/cometchat_error_conversations_subtitle"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_error_state_title"
                app:layout_constraintWidth_percent="0.8" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nested_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/conversations_recyclerview_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/conversations_section_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/cometchat_margin_4"
                    android:layout_marginVertical="@dimen/cometchat_margin_2"
                    android:visibility="gone"
                    android:text="@string/cometchat_chats" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerview_conversations"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:overScrollMode="never"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone"
                    android:layout_marginHorizontal="@dimen/cometchat_margin_4"/>

                <TextView
                    android:id="@+id/conversations_see_more"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cometchat_see_more"
                    android:layout_marginVertical="@dimen/cometchat_margin_2"
                    android:layout_marginHorizontal="@dimen/cometchat_margin_4"
                    android:visibility="gone"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/messages_recyclerview_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/messages_section_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/cometchat_margin_4"
                    android:layout_marginVertical="@dimen/cometchat_margin_2"
                    android:visibility="gone"
                    android:text="@string/cometchat_messages" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerview_messages"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"
                    android:visibility="gone"
                    android:layout_marginHorizontal="@dimen/cometchat_margin_4"/>

                <TextView
                    android:id="@+id/messages_see_more"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cometchat_see_more"
                    android:layout_marginVertical="@dimen/cometchat_margin_2"
                    android:layout_marginHorizontal="@dimen/cometchat_margin_4"
                    android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>