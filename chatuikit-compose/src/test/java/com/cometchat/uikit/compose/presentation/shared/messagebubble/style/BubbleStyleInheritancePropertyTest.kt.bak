package com.cometchat.uikit.compose.presentation.shared.messagebubble.style

import androidx.compose.foundation.layout.PaddingValues
import androidx.compose.ui.graphics.Color
import androidx.compose.ui.text.TextStyle
import androidx.compose.ui.unit.Dp
import androidx.compose.ui.unit.dp
import androidx.compose.ui.unit.sp
import com.cometchat.uikit.compose.presentation.shared.baseelements.avatar.CometChatAvatarStyle
import io.kotest.core.spec.style.StringSpec
import io.kotest.matchers.types.shouldBeInstanceOf
import io.kotest.property.Arb
import io.kotest.property.arbitrary.bind
import io.kotest.property.arbitrary.float
import io.kotest.property.arbitrary.int
import io.kotest.property.arbitrary.map
import io.kotest.property.checkAll

/**
 * Property-based tests for verifying that all per-bubble-type styles are subtypes
 * of CometChatMessageBubbleStyle.
 *
 * **Feature: bubble-style-propagation**
 * **Property 1: All per-bubble-type styles are subtypes of CometChatMessageBubbleStyle**
 *
 * **Validates: Requirements 2.1**
 *
 * For any per-bubble-type style instance (TextBubbleStyle, ImageBubbleStyle, AudioBubbleStyle,
 * VideoBubbleStyle, FileBubbleStyle, DeleteBubbleStyle, StickerBubbleStyle, PollBubbleStyle,
 * CollaborativeBubbleStyle, MeetCallBubbleStyle, ActionBubbleStyle, CallActionBubbleStyle),
 * the instance should be assignable to a variable of type `CometChatMessageBubbleStyle` —
 * confirming the inheritance relationship holds.
 */
class BubbleStyleInheritancePropertyTest : StringSpec({

    // ============================================================================
    // Arbitrary generators for common wrapper properties
    // ============================================================================

    /**
     * Generates random Color values for testing.
     */
    val colorArb = Arb.bind(
        Arb.int(0, 255),
        Arb.int(0, 255),
        Arb.int(0, 255),
        Arb.int(0, 255)
    ) { r, g, b, a -> Color(r / 255f, g / 255f, b / 255f, a / 255f) }


    /**
     * Generates random Dp values for testing.
     */
    val dpArb: Arb<Dp> = Arb.float(0f, 24f).map { value -> value.dp }

    /**
     * Generates random TextStyle values for testing.
     */
    val textStyleArb: Arb<TextStyle> = Arb.float(10f, 24f).map { fontSize -> TextStyle(fontSize = fontSize.sp) }

    /**
     * Generates random PaddingValues for testing.
     */
    val paddingArb: Arb<PaddingValues> = Arb.float(0f, 16f).map { padding -> PaddingValues(padding.dp) }

    // ============================================================================
    // Property Test: CometChatTextBubbleStyle is subtype of CometChatMessageBubbleStyle
    // ============================================================================

    /**
     * Property test: CometChatTextBubbleStyle instances are subtypes of CometChatMessageBubbleStyle.
     *
     * **Validates: Requirements 2.1**
     */
    "CometChatTextBubbleStyle should be a subtype of CometChatMessageBubbleStyle" {
        val textBubbleStyleArb = Arb.bind(
            colorArb, // textColor
            colorArb, // linkColor
            colorArb, // backgroundColor
            dpArb     // cornerRadius
        ) { textColor, linkColor, backgroundColor, cornerRadius ->
            createTestTextBubbleStyle(
                textColor = textColor,
                linkColor = linkColor,
                backgroundColor = backgroundColor,
                cornerRadius = cornerRadius
            )
        }

        checkAll(100, textBubbleStyleArb) { style ->
            style.shouldBeInstanceOf<CometChatMessageBubbleStyle>()
        }
    }


    // ============================================================================
    // Property Test: CometChatImageBubbleStyle is subtype of CometChatMessageBubbleStyle
    // ============================================================================

    /**
     * Property test: CometChatImageBubbleStyle instances are subtypes of CometChatMessageBubbleStyle.
     *
     * **Validates: Requirements 2.1**
     */
    "CometChatImageBubbleStyle should be a subtype of CometChatMessageBubbleStyle" {
        val imageBubbleStyleArb = Arb.bind(
            dpArb,    // imageCornerRadius
            colorArb, // captionTextColor
            colorArb, // backgroundColor
            dpArb     // cornerRadius
        ) { imageCornerRadius, captionTextColor, backgroundColor, cornerRadius ->
            createTestImageBubbleStyle(
                imageCornerRadius = imageCornerRadius,
                captionTextColor = captionTextColor,
                backgroundColor = backgroundColor,
                cornerRadius = cornerRadius
            )
        }

        checkAll(100, imageBubbleStyleArb) { style ->
            style.shouldBeInstanceOf<CometChatMessageBubbleStyle>()
        }
    }

    // ============================================================================
    // Property Test: CometChatAudioBubbleStyle is subtype of CometChatMessageBubbleStyle
    // ============================================================================

    /**
     * Property test: CometChatAudioBubbleStyle instances are subtypes of CometChatMessageBubbleStyle.
     *
     * **Validates: Requirements 2.1**
     */
    "CometChatAudioBubbleStyle should be a subtype of CometChatMessageBubbleStyle" {
        val audioBubbleStyleArb = Arb.bind(
            colorArb, // playIconTint
            colorArb, // audioWaveColor
            colorArb, // backgroundColor
            dpArb     // cornerRadius
        ) { playIconTint, audioWaveColor, backgroundColor, cornerRadius ->
            createTestAudioBubbleStyle(
                playIconTint = playIconTint,
                audioWaveColor = audioWaveColor,
                backgroundColor = backgroundColor,
                cornerRadius = cornerRadius
            )
        }

        checkAll(100, audioBubbleStyleArb) { style ->
            style.shouldBeInstanceOf<CometChatMessageBubbleStyle>()
        }
    }


    // ============================================================================
    // Property Test: CometChatVideoBubbleStyle is subtype of CometChatMessageBubbleStyle
    // ============================================================================

    /**
     * Property test: CometChatVideoBubbleStyle instances are subtypes of CometChatMessageBubbleStyle.
     *
     * **Validates: Requirements 2.1**
     */
    "CometChatVideoBubbleStyle should be a subtype of CometChatMessageBubbleStyle" {
        val videoBubbleStyleArb = Arb.bind(
            dpArb,    // videoCornerRadius
            colorArb, // playIconTint
            colorArb, // backgroundColor
            dpArb     // cornerRadius
        ) { videoCornerRadius, playIconTint, backgroundColor, cornerRadius ->
            createTestVideoBubbleStyle(
                videoCornerRadius = videoCornerRadius,
                playIconTint = playIconTint,
                backgroundColor = backgroundColor,
                cornerRadius = cornerRadius
            )
        }

        checkAll(100, videoBubbleStyleArb) { style ->
            style.shouldBeInstanceOf<CometChatMessageBubbleStyle>()
        }
    }

    // ============================================================================
    // Property Test: CometChatFileBubbleStyle is subtype of CometChatMessageBubbleStyle
    // ============================================================================

    /**
     * Property test: CometChatFileBubbleStyle instances are subtypes of CometChatMessageBubbleStyle.
     *
     * **Validates: Requirements 2.1**
     */
    "CometChatFileBubbleStyle should be a subtype of CometChatMessageBubbleStyle" {
        val fileBubbleStyleArb = Arb.bind(
            dpArb,    // innerCornerRadius
            colorArb, // titleTextColor
            colorArb, // backgroundColor
            dpArb     // cornerRadius
        ) { innerCornerRadius, titleTextColor, backgroundColor, cornerRadius ->
            createTestFileBubbleStyle(
                innerCornerRadius = innerCornerRadius,
                titleTextColor = titleTextColor,
                backgroundColor = backgroundColor,
                cornerRadius = cornerRadius
            )
        }

        checkAll(100, fileBubbleStyleArb) { style ->
            style.shouldBeInstanceOf<CometChatMessageBubbleStyle>()
        }
    }


    // ============================================================================
    // Property Test: CometChatDeleteBubbleStyle is subtype of CometChatMessageBubbleStyle
    // ============================================================================

    /**
     * Property test: CometChatDeleteBubbleStyle instances are subtypes of CometChatMessageBubbleStyle.
     *
     * **Validates: Requirements 2.1**
     */
    "CometChatDeleteBubbleStyle should be a subtype of CometChatMessageBubbleStyle" {
        val deleteBubbleStyleArb = Arb.bind(
            colorArb, // textColor
            colorArb, // iconTint
            colorArb, // backgroundColor
            dpArb     // cornerRadius
        ) { textColor, iconTint, backgroundColor, cornerRadius ->
            createTestDeleteBubbleStyle(
                textColor = textColor,
                iconTint = iconTint,
                backgroundColor = backgroundColor,
                cornerRadius = cornerRadius
            )
        }

        checkAll(100, deleteBubbleStyleArb) { style ->
            style.shouldBeInstanceOf<CometChatMessageBubbleStyle>()
        }
    }

    // ============================================================================
    // Property Test: CometChatStickerBubbleStyle is subtype of CometChatMessageBubbleStyle
    // ============================================================================

    /**
     * Property test: CometChatStickerBubbleStyle instances are subtypes of CometChatMessageBubbleStyle.
     *
     * **Validates: Requirements 2.1**
     */
    "CometChatStickerBubbleStyle should be a subtype of CometChatMessageBubbleStyle" {
        val stickerBubbleStyleArb = Arb.bind(
            colorArb, // backgroundColor
            dpArb,    // cornerRadius
            colorArb, // senderNameTextColor
            colorArb  // threadIndicatorIconTint
        ) { backgroundColor, cornerRadius, senderNameTextColor, threadIndicatorIconTint ->
            createTestStickerBubbleStyle(
                backgroundColor = backgroundColor,
                cornerRadius = cornerRadius,
                senderNameTextColor = senderNameTextColor,
                threadIndicatorIconTint = threadIndicatorIconTint
            )
        }

        checkAll(100, stickerBubbleStyleArb) { style ->
            style.shouldBeInstanceOf<CometChatMessageBubbleStyle>()
        }
    }


    // ============================================================================
    // Property Test: CometChatPollBubbleStyle is subtype of CometChatMessageBubbleStyle
    // ============================================================================

    /**
     * Property test: CometChatPollBubbleStyle instances are subtypes of CometChatMessageBubbleStyle.
     *
     * **Validates: Requirements 2.1**
     */
    "CometChatPollBubbleStyle should be a subtype of CometChatMessageBubbleStyle" {
        val pollBubbleStyleArb = Arb.bind(
            colorArb, // titleTextColor
            colorArb, // progressColor
            colorArb, // backgroundColor
            dpArb     // cornerRadius
        ) { titleTextColor, progressColor, backgroundColor, cornerRadius ->
            createTestPollBubbleStyle(
                titleTextColor = titleTextColor,
                progressColor = progressColor,
                backgroundColor = backgroundColor,
                cornerRadius = cornerRadius
            )
        }

        checkAll(100, pollBubbleStyleArb) { style ->
            style.shouldBeInstanceOf<CometChatMessageBubbleStyle>()
        }
    }

    // ============================================================================
    // Property Test: CometChatCollaborativeBubbleStyle is subtype of CometChatMessageBubbleStyle
    // ============================================================================

    /**
     * Property test: CometChatCollaborativeBubbleStyle instances are subtypes of CometChatMessageBubbleStyle.
     *
     * **Validates: Requirements 2.1**
     */
    "CometChatCollaborativeBubbleStyle should be a subtype of CometChatMessageBubbleStyle" {
        val collaborativeBubbleStyleArb = Arb.bind(
            colorArb, // titleTextColor
            colorArb, // iconTint
            colorArb, // backgroundColor
            dpArb     // cornerRadius
        ) { titleTextColor, iconTint, backgroundColor, cornerRadius ->
            createTestCollaborativeBubbleStyle(
                titleTextColor = titleTextColor,
                iconTint = iconTint,
                backgroundColor = backgroundColor,
                cornerRadius = cornerRadius
            )
        }

        checkAll(100, collaborativeBubbleStyleArb) { style ->
            style.shouldBeInstanceOf<CometChatMessageBubbleStyle>()
        }
    }


    // ============================================================================
    // Property Test: CometChatMeetCallBubbleStyle is subtype of CometChatMessageBubbleStyle
    // ============================================================================

    /**
     * Property test: CometChatMeetCallBubbleStyle instances are subtypes of CometChatMessageBubbleStyle.
     *
     * **Validates: Requirements 2.1**
     */
    "CometChatMeetCallBubbleStyle should be a subtype of CometChatMessageBubbleStyle" {
        val meetCallBubbleStyleArb = Arb.bind(
            colorArb, // callIconTint
            colorArb, // titleTextColor
            colorArb, // backgroundColor
            dpArb     // cornerRadius
        ) { callIconTint, titleTextColor, backgroundColor, cornerRadius ->
            createTestMeetCallBubbleStyle(
                callIconTint = callIconTint,
                titleTextColor = titleTextColor,
                backgroundColor = backgroundColor,
                cornerRadius = cornerRadius
            )
        }

        checkAll(100, meetCallBubbleStyleArb) { style ->
            style.shouldBeInstanceOf<CometChatMessageBubbleStyle>()
        }
    }

    // ============================================================================
    // Property Test: CometChatActionBubbleStyle is subtype of CometChatMessageBubbleStyle
    // ============================================================================

    /**
     * Property test: CometChatActionBubbleStyle instances are subtypes of CometChatMessageBubbleStyle.
     *
     * **Validates: Requirements 2.1**
     */
    "CometChatActionBubbleStyle should be a subtype of CometChatMessageBubbleStyle" {
        val actionBubbleStyleArb = Arb.bind(
            colorArb, // textColor
            colorArb, // backgroundColor
            dpArb,    // cornerRadius
            colorArb  // senderNameTextColor
        ) { textColor, backgroundColor, cornerRadius, senderNameTextColor ->
            createTestActionBubbleStyle(
                textColor = textColor,
                backgroundColor = backgroundColor,
                cornerRadius = cornerRadius,
                senderNameTextColor = senderNameTextColor
            )
        }

        checkAll(100, actionBubbleStyleArb) { style ->
            style.shouldBeInstanceOf<CometChatMessageBubbleStyle>()
        }
    }


    // ============================================================================
    // Property Test: CometChatCallActionBubbleStyle is subtype of CometChatMessageBubbleStyle
    // ============================================================================

    /**
     * Property test: CometChatCallActionBubbleStyle instances are subtypes of CometChatMessageBubbleStyle.
     *
     * **Validates: Requirements 2.1**
     */
    "CometChatCallActionBubbleStyle should be a subtype of CometChatMessageBubbleStyle" {
        val callActionBubbleStyleArb = Arb.bind(
            colorArb, // textColor
            colorArb, // iconTint
            colorArb, // backgroundColor
