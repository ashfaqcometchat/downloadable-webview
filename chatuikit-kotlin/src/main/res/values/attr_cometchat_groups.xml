<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="CometChatGroups">
        <!-- Style reference -->
        <attr name="cometchatGroupsStyle" format="reference" />
        
        <!-- Container styling -->
        <attr name="cometchatGroupsBackgroundColor" format="color" />
        <attr name="cometchatGroupsStrokeWidth" format="dimension" />
        <attr name="cometchatGroupsStrokeColor" format="color" />
        <attr name="cometchatGroupsCornerRadius" format="dimension" />

        <!-- Toolbar styling -->
        <attr name="cometchatGroupsTitleTextColor" format="color" />
        <attr name="cometchatGroupsTitleTextAppearance" format="reference" />
        <attr name="cometchatGroupsBackIcon" format="reference" />
        <attr name="cometchatGroupsBackIconTint" format="color" />
        <attr name="cometchatGroupsSeparatorColor" format="color" />
        <attr name="cometchatGroupsSeparatorHeight" format="dimension" />

        <!-- Selection icons -->
        <attr name="cometchatGroupsDiscardSelectionIcon" format="reference" />
        <attr name="cometchatGroupsDiscardSelectionIconTint" format="color" />
        <attr name="cometchatGroupsSubmitSelectionIcon" format="reference" />
        <attr name="cometchatGroupsSubmitSelectionIconTint" format="color" />

        <!-- Search box styling -->
        <attr name="cometchatGroupsSearchInputBackgroundColor" format="color" />
        <attr name="cometchatGroupsSearchInputTextColor" format="color" />
        <attr name="cometchatGroupsSearchInputTextAppearance" format="reference" />
